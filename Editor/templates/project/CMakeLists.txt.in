cmake_minimum_required(VERSION 3.20)
project({{PROJECT_NAME}} LANGUAGES CXX)

set(CMAKE_CXX_STANDARD 20)
set(CMAKE_CXX_STANDARD_REQUIRED ON)

option(NEXUS_PROJECT_EDITOR_MODE "Build the project as an editor-loaded game DLL" OFF)
if(NEXUS_PROJECT_EDITOR_MODE)
    set(NEXUS_EDITOR_MODE ON CACHE BOOL "" FORCE)
else()
    set(NEXUS_EDITOR_MODE OFF CACHE BOOL "" FORCE)
endif()

if(NOT DEFINED NEXUS_PROJECT_OUTPUT_SUBDIR OR NEXUS_PROJECT_OUTPUT_SUBDIR STREQUAL "")
    string(TOLOWER "${CMAKE_BUILD_TYPE}" NEXUS_PROJECT_BUILD_TYPE_LOWER)
    if(BUILD_WEB)
        set(NEXUS_PROJECT_OUTPUT_PLATFORM "web")
    elseif(NEXUS_PROJECT_EDITOR_MODE)
        set(NEXUS_PROJECT_OUTPUT_PLATFORM "editor")
    elseif(CMAKE_SIZEOF_VOID_P EQUAL 8)
        set(NEXUS_PROJECT_OUTPUT_PLATFORM "x64")
    else()
        set(NEXUS_PROJECT_OUTPUT_PLATFORM "x86")
    endif()

    if(NEXUS_PROJECT_BUILD_TYPE_LOWER STREQUAL "release")
        set(NEXUS_PROJECT_OUTPUT_SUBDIR "${NEXUS_PROJECT_OUTPUT_PLATFORM}-release")
    else()
        set(NEXUS_PROJECT_OUTPUT_SUBDIR "${NEXUS_PROJECT_OUTPUT_PLATFORM}-debug")
    endif()
endif()

set(CMAKE_RUNTIME_OUTPUT_DIRECTORY "${CMAKE_CURRENT_SOURCE_DIR}/Binaries/${NEXUS_PROJECT_OUTPUT_SUBDIR}")
set(CMAKE_RUNTIME_OUTPUT_DIRECTORY_DEBUG "${CMAKE_CURRENT_SOURCE_DIR}/Binaries/${NEXUS_PROJECT_OUTPUT_SUBDIR}")
set(CMAKE_RUNTIME_OUTPUT_DIRECTORY_RELEASE "${CMAKE_CURRENT_SOURCE_DIR}/Binaries/${NEXUS_PROJECT_OUTPUT_SUBDIR}")
set(CMAKE_LIBRARY_OUTPUT_DIRECTORY "${CMAKE_CURRENT_SOURCE_DIR}/Binaries/${NEXUS_PROJECT_OUTPUT_SUBDIR}")
set(CMAKE_LIBRARY_OUTPUT_DIRECTORY_DEBUG "${CMAKE_CURRENT_SOURCE_DIR}/Binaries/${NEXUS_PROJECT_OUTPUT_SUBDIR}")
set(CMAKE_LIBRARY_OUTPUT_DIRECTORY_RELEASE "${CMAKE_CURRENT_SOURCE_DIR}/Binaries/${NEXUS_PROJECT_OUTPUT_SUBDIR}")
set(CMAKE_ARCHIVE_OUTPUT_DIRECTORY "${CMAKE_CURRENT_SOURCE_DIR}/Intermediate/${NEXUS_PROJECT_OUTPUT_SUBDIR}")
set(CMAKE_ARCHIVE_OUTPUT_DIRECTORY_DEBUG "${CMAKE_CURRENT_SOURCE_DIR}/Intermediate/${NEXUS_PROJECT_OUTPUT_SUBDIR}")
set(CMAKE_ARCHIVE_OUTPUT_DIRECTORY_RELEASE "${CMAKE_CURRENT_SOURCE_DIR}/Intermediate/${NEXUS_PROJECT_OUTPUT_SUBDIR}")
set(CMAKE_PDB_OUTPUT_DIRECTORY "${CMAKE_CURRENT_SOURCE_DIR}/Intermediate/${NEXUS_PROJECT_OUTPUT_SUBDIR}")
set(CMAKE_PDB_OUTPUT_DIRECTORY_DEBUG "${CMAKE_CURRENT_SOURCE_DIR}/Intermediate/${NEXUS_PROJECT_OUTPUT_SUBDIR}")
set(CMAKE_PDB_OUTPUT_DIRECTORY_RELEASE "${CMAKE_CURRENT_SOURCE_DIR}/Intermediate/${NEXUS_PROJECT_OUTPUT_SUBDIR}")

set(CMAKE_OBJECT_PATH_MAX 128)
set(NEXUS_BUILD_EDITOR OFF CACHE BOOL "" FORCE)
set(NEXUS_BUILD_SAMPLE_PROJECTS OFF CACHE BOOL "" FORCE)
set(NEXUS_WORKSPACE_SOURCE "{{WORKSPACE_ROOT}}")
set(NEXUS_WORKSPACE_SUBST_DRIVE "N:")
if(WIN32)
    execute_process(COMMAND cmd /c subst ${NEXUS_WORKSPACE_SUBST_DRIVE} "${NEXUS_WORKSPACE_SOURCE}" OUTPUT_QUIET ERROR_QUIET)
    if(EXISTS "${NEXUS_WORKSPACE_SUBST_DRIVE}/CMakeLists.txt")
        set(NEXUS_WORKSPACE_SOURCE "${NEXUS_WORKSPACE_SUBST_DRIVE}/")
    endif()
endif()
add_subdirectory("${NEXUS_WORKSPACE_SOURCE}" W)

if(NEXUS_PROJECT_EDITOR_MODE)
    add_library({{PROJECT_NAME}} SHARED
        src/Game.cpp
    )
else()
    add_executable({{PROJECT_NAME}}
        src/Game.cpp
        src/main_win32.cpp
    )
endif()

target_link_libraries({{PROJECT_NAME}} PRIVATE NexusEngine)
target_include_directories({{PROJECT_NAME}} PRIVATE
    "${NEXUS_WORKSPACE_SOURCE}/NexusEngine/src"
)
if(NEXUS_PROJECT_EDITOR_MODE)
    target_compile_definitions({{PROJECT_NAME}} PRIVATE PROJECTGAME_EXPORTS)
else()
    target_link_libraries({{PROJECT_NAME}} PRIVATE NEXUS_SDL)
endif()

if(WIN32)
    add_custom_command(TARGET {{PROJECT_NAME}} POST_BUILD
        COMMAND ${CMAKE_COMMAND} -E copy_if_different $<TARGET_RUNTIME_DLLS:{{PROJECT_NAME}}> $<TARGET_FILE_DIR:{{PROJECT_NAME}}>
        COMMAND_EXPAND_LISTS
        COMMENT "Copying runtime DLLs for {{PROJECT_NAME}}")
endif()
